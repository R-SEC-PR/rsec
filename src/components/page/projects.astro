---
import { Image } from "astro:assets";
import projectsData from "../../data/projects.json";
import type { projectsJson } from "../../types";
import getOptimizedImages from "../../utils/optimizedImages"

import { icon,library } from "@fortawesome/fontawesome-svg-core";
import { faAngleRight } from "@fortawesome/free-solid-svg-icons";
library.add(faAngleRight);
const rightIcon=icon(faAngleRight);

//画像取得
const images=import.meta.glob("../../assets/projectImages/*",{eager:true});
const folderPath="../../assets";
const thumbnails :Record<string,ImageMetadata>=getOptimizedImages(projectsData.map(value=>(`${folderPath}/${value.imgpath}`)).filter(value=>value!==null),images);
console.log(thumbnails);
---
<section id="projects" class="section">
    <div class="container">
    <div class="section-header">
        <h2 class="section-title">PROJECTS</h2>
        <p style="color: var(--gray-light)">
        航空宇宙に興味のある学生が切磋琢磨中！！あなたも一緒にどうですか？
        </p>
    </div>

    <div class="project-grid">
        {
            projectsData.map((value,index)=>(
            <div class="project-card">
                <div class="project-img">
                    {value.imgpath && <Image
                      src={thumbnails[`${folderPath}/${value.imgpath}`]}
                      alt={value.title}
                      format="webp"
                      quality={70}
                      />
                    }
                </div>
                <div class="project-content">
                    <div class="project-tag">Project {value.id.toString().padStart(2,"0")}</div>
                    <h3 class="project-name">{value.title}</h3>
                    <p class="project-desc">
                    {value.description}
                    </p>
                    {value.pagepath?
                        <a href={value.pagepath} class="project-link">
                        詳しく見る <span set:html={rightIcon.html} />
                        </a>
                        :
                        <p class="project-link" style="color: var(--gray-mid); cursor: default">
                            Coming Soon
                        </p>
                    }
                </div>
            </div>
            ))
        }
    </div>
    </div>
</section>
<style lang="scss">
      .section {
        padding: 100px 0;
      }

      .section-header {
        text-align: center;
        margin-bottom: 60px;
      }

      .section-title {
        font-size: 2.5rem;
        font-weight: 900;
        margin-bottom: 16px;
      }

      .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 30px;
      }

      .project-card {
        background: $dark2;
        border-radius: $radius-lg;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: $transition;
        display: flex;
        flex-direction: column;
      }

      .project-card:hover {
        transform: translateY(-10px);
        border-color: rgba(245, 196, 0, 0.3);
        box-shadow: $shadow-lg;
      }

      .project-img {
        height: 240px;
        overflow: hidden;
      }

      .project-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: $transition;
      }

      .project-card:hover .project-img img {
        transform: scale(1.1);
      }

      .project-content {
        padding: 30px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
      }

      .project-tag {
        font-family: $font-en;
        font-size: 0.7rem;
        color: $yellow;
        letter-spacing: 0.1em;
        margin-bottom: 12px;
        text-transform: uppercase;
      }

      .project-name {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 16px;
      }

      .project-desc {
        color: $gray-light;
        margin-bottom: 24px;
        font-size: 0.95rem;
      }

      .project-link {
        margin-top: auto;
        color: yellow;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
      }
</style>