---
export interface Props{
    navData:Array<{name:string,path:string,outer?:boolean}>;
}
const {navData}=Astro.props;
---
<nav class="accordion">
    <input id="accordion_check" type="checkbox"/>
    <label for="accordion_check" class="accordion__btn">
        <hr class="hamb_line line_1" />
        <hr class="hamb_line line_2" />
        <hr class="hamb_line line_3" />
    </label>
    <div class="accordion__panel">
        <ul class="accordion__panel__content">
            {navData.map(value=>(
                <li class="accordion__panel__link"><a
                    
                    href={value.path}
                    target={value.outer?"_blank":"_self"}
                >
                    {value.name}
                </a></li>
            ))}
        </ul>
    </div>
</nav>
<style lang="scss">
    .accordion{
        input{display:none;}
        &__btn{
            position:relative;
            cursor:pointer;
            display:block;
            width:$header-height;
            height:$header-height;
        }
        &__panel{
            position:absolute;
            display:block;
            top:$header-height;
            right:0;
            width:100dvw;
            display: grid;
            grid-template-rows: 0fr; /* 最初は高さ0 */
            transition: grid-template-rows 0.3s ease; /* スルスル伸びる設定 */
            overflow: hidden;
            background-color:$black;
            &__content{
                min-height:0;
                text-align:right;
                margin-right:16px;
                margin-bottom:8px;
            }
            &__link{
                color:$white;
                font-size:1.4rem;
                &:hover{color:$yellow;}
            }
        }
        .hamb_line{
            width:70%;
            height:2px;
            border-radius: 1px;
            background:$white;
            position:absolute;
            left:15%;
            &.line_1{
                top:28%;
                transition:transform 0.5s ease;
            }
            &.line_2{
                opacity:1;
                top:50%;
                transition:opacity 0.3s ease;
            }
            &.line_3{
                top:72%;
                transition:transform 0.5s ease;
            }
        }

    }
    .accordion:has(input:checked){
        .accordion__panel{
            grid-template-rows:1fr;
        }
        .hamb_line{
            &.line_1{
                transform:translateY(calc($header-height * 0.22)) rotateZ(45deg);
            }
            &.line_3{
                transform:translateY(calc($header-height * -0.22)) rotateZ(-45deg);
            }
            &.line_2{
                opacity:0;
            }
        }
    }
</style>